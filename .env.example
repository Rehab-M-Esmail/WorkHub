
# --- Ports (host machine) ----------------------------------------------------
POSTGRES_HOST_PORT=5433
APP_HOST_PORT=8080
KAFKA_HOST_PORT=9092
REDPANDA_ADMIN_HOST_PORT=9644
PROMETHEUS_HOST_PORT=9091
GRAFANA_HOST_PORT=3000

# --- PostgreSQL (docker-compose postgres + JDBC for app) --------------------
POSTGRES_DB=workhub
POSTGRES_USER=workhub
POSTGRES_PASSWORD=workhub

# DB_HOST = Postgres hostname from the app container (service name in Compose).
DB_HOST=postgres
DB_USERNAME=workhub
DB_PASSWORD=workhub

# Full JDBC URL (optional). When set, Spring Boot uses it as spring.datasource.url.
SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/workhub
SPRING_DATASOURCE_USERNAME=workhub
SPRING_DATASOURCE_PASSWORD=workhub

# --- Apache Kafka / Redpanda -------------------------------------------------
KAFKA_BOOTSTRAP_SERVERS=redpanda:9092
WORKHUB_KAFKA_TOPICS_REPORT_REQUESTED=workhub.report.requested.v1
WORKHUB_REPORT_PROCESSING_DELAY_MS=1500

# --- JWT (maps to auth.secretKey; change for any shared/deployed env) -------
AUTH_SECRETKEY=WorkHubWorkinghubbbbhfdhfgueusfuherfqwoeierf345vg43tv44vt5463

# --- JPA ---------------------------------------------------------------------
SPRING_JPA_HIBERNATE_DDL_AUTO=update

# --- OpenTelemetry (when spring-boot-starter-opentelemetry is on classpath) ---
MANAGEMENT_TRACING_SAMPLING_PROBABILITY=1.0
MANAGEMENT_OPENTELEMETRY_TRACING_EXPORT_OTLP_ENDPOINT=http://tempo:4318/v1/traces

# --- Grafana -----------------------------------------------------------------
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=admin
GF_USERS_ALLOW_SIGN_UP=false

# --- Host-side / CI-style (for local mvn test; not used by default compose) --
# DB_HOST=127.0.0.1
# SPRING_DATASOURCE_URL=jdbc:postgresql://127.0.0.1:5432/workhub
# SPRING_DATASOURCE_USERNAME=postgres
# SPRING_DATASOURCE_PASSWORD=postgres
# TESTCONTAINERS_RYUK_DISABLED=true
